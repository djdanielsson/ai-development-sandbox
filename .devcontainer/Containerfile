# syntax=docker/dockerfile:1
# --- Base Image (pinned by version + digest for reproducibility) ---
# Dependabot tracks the `fedora` image and opens PRs when new digests are published.
# IMPORTANT: Use the fully qualified docker.io reference. Podman's shortname alias
# resolves bare "fedora" to registry.fedoraproject.org which may not carry the same
# digest as Docker Hub, causing "manifest unknown" errors.
# To update manually: podman inspect docker.io/library/fedora:43 --format '{{.Digest}}'
FROM docker.io/library/fedora:43@sha256:781b7642e8bf256e9cf75d2aa58d86f5cc695fd2df113517614e181a5eee9138

# --- System Packages ---
# Versions are locked to specific releases so builds are reproducible.
# Dependabot cannot update these; run `scripts/update-dnf-versions.sh` to refresh.

ARG DNF_PACKAGES="\
    podman-5:5.8.1-1.fc43 \
    curl-8.15.0-5.fc43 \
    git-2.53.0-1.fc43 \
    tar-2:1.35-6.fc43 \
    sudo-1.9.17-6.p2.fc43 \
    procps-ng-4.0.4-7.fc43.1 \
    findutils-1:4.10.0-6.fc43 \
    gh-2.87.3-1.fc43 \
    zsh-5.9-19.fc43 \
    fzf-0.70.0-1.fc43 \
    eza-0.23.4-1.fc43 \
    zoxide-0.9.8-1.fc43 \
    vim-enhanced-2:9.2.280-1.fc43 \
    gettext-envsubst-0.25.1-2.fc43 \
    jq-1.8.1-1.fc43 \
    unzip-6.0-67.fc43 \
    dnf5-5.2.18.0-2.fc43 \
    dnf5-plugins-5.2.18.0-2.fc43 \
    libdnf5-5.2.18.0-2.fc43 \
    libdnf5-cli-5.2.18.0-2.fc43 \
    gnutls-3.8.12-1.fc43 \
    libssh-0.11.4-1.fc43 \
    libtasn1-4.21.0-1.fc43 \
    systemd-standalone-sysusers-258.7-1.fc43 \
"

RUN dnf install -y --setopt=install_weak_deps=False $DNF_PACKAGES && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# --- Nested Podman Configuration ---
# The outer container runtime does not delegate cgroup controllers, so the
# inner Podman cannot create or manage cgroup subtrees. Setting
# cgroups="disabled" under [containers] tells Podman to skip cgroup setup
# entirely (resource limits on inner containers won't be enforced, which is
# acceptable for a dev environment).
# cgroup_manager="cgroupfs" is required (not systemd, which isn't running).
# events_logger="file" avoids the missing systemd journal.
RUN printf '[containers]\ncgroups = "disabled"\n\n[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' > /etc/containers/containers.conf

# --- Tools (AI agents, CLIs, shell setup) ---
# Everything that downloads binaries or runs curl|bash installers lives in
# install-tools.sh so it can detect the build architecture at RUN time.
# AUDIT: review each URL's install script before building.
COPY scripts/install-tools.sh /tmp/install-tools.sh
RUN chmod +x /tmp/install-tools.sh && /tmp/install-tools.sh && rm /tmp/install-tools.sh

# --- Container init script (runs at each container start) ---
COPY scripts/container-init.sh /usr/local/bin/container-init.sh
RUN chmod +x /usr/local/bin/container-init.sh

ENV PATH="/root/.local/bin:${PATH}"
